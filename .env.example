# Copy to .env and fill in values. Never commit .env to git.

PORT=3000

DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASS=your_password
DB_NAME=ghoulhr_master
DB_LOGGING=true

TENANT_DB_HOST=localhost
TENANT_DB_PORT=5432
TENANT_DB_USER=postgres
TENANT_DB_PASS=your_password
TENANT_DB_SUFFIX=_db
TENANT_CONNECTION_POOL_SIZE=10

JWT_SECRET=change_me
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
AUTH_SESSION_MAX_LIFETIME=24h
NODE_ENV=local
APP_DOMAIN=ghoulhr.com
BOOTSTRAP_ADMIN_KEY=change_me

RBAC_SCOPE_V2=true

# AWS S3 (required for file uploads — logo, documents, profile photos)
AWS_REGION=ap-southeast-2
AWS_BUCKET_NAME=your-bucket-name
AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key
# Optional
# AWS_S3_SSE=AES256
# AWS_S3_SIGNED_URL_TTL_SECONDS=900
# STORAGE_MAX_FILE_BYTES=5242880

# AWS SES (SMTP — required for email notifications)
AWS_SES_SMTP_ENDPOINT=email-smtp.ap-southeast-2.amazonaws.com
AWS_SES_SMTP_PORT=587
AWS_SES_SMTP_USERNAME=your_ses_smtp_username
AWS_SES_SMTP_PASSWORD=your_ses_smtp_password
AWS_SES_FROM_EMAIL=info@your-verified-domain
AWS_SES_FROM_NAME=GhoulHR
